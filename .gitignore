# PlatformIO
.pio/
.vscode/
# clangd compilation database — regenerated locally with `pio run -t compiledb`
compile_commands.json
# Per-developer clangd config — typically pins the absolute path to the
# xtensa toolchain binary, which differs by username/$HOME.
.clangd

# Frontend
node_modules/
dist/

# Built SPIFFS data (regenerated by build)
**/firmware/data/

# Release artifacts
release/

# Local OTA artifact dump (per-developer, generated by `release.sh`
# without --output-dir).
local-ota/

# Per-developer Claude Code session state — locally-managed agent
# memory/locks; nothing in here belongs in version control.
.claude/

# Serena
.serena/

# Python virtual envs
.venv/
__pycache__/

# OS
.DS_Store
Thumbs.db

# IDE
*.swp
*.swo
*~

# Cache for build tools, e.g. PlatformIO's PIO Home and its dependencies.
.pio/
.cache

.env

# Cached source TTFs for console/scripts/build_fonts.sh — downloaded on demand,
# never distributed (the generated .c files under firmware/src/fonts/ are).
/console/fonts/
